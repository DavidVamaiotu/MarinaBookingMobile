{
  "name": "marina-booking-desktop",
  "version": "1.0.17",
  "description": "Fast offline-capable Electron manager for Marina Booking API reservations",
  "main": "electron-main.js",
  "author": "Marina Park",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "check": "node scripts/check-syntax.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis --x64 --publish never",
    "mobile:web": "node scripts/build-mobile-web.js",
    "mobile:sync": "npm run mobile:web && cap sync android",
    "mobile:apk": "node scripts/build-android.js"
  },
  "devDependencies": {
    "@aparajita/capacitor-secure-storage": "6.0.1",
    "@capacitor/android": "6.2.1",
    "@capacitor/app": "6.0.3",
    "@capacitor/cli": "6.2.1",
    "@capacitor/core": "6.2.1",
    "@capacitor/preferences": "6.0.4",
    "electron": "39.8.10",
    "electron-builder": "26.15.3",
    "esbuild": "0.25.6"
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "electron-winstaller@5.4.0": true
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
