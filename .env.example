# The desktop UI stores non-secret settings in its local SQLite database.
# The Application Password is never read from .env; enter it in Settings so
# Electron can encrypt it with the operating-system credential service.
MARINA_BOOKING_API_URL=https://example.com/wp-json/marina-booking/v1
MARINA_BOOKING_API_USERNAME=dedicated-api-user
MARINA_BOOKING_TIMEZONE=Europe/Bucharest
