#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

DESKTOP_REPO="DavidVamaiotu/MarinaBookingDesktop"
MOBILE_REPO="DavidVamaiotu/MarinaBookingMobile"
DESKTOP_WORKFLOW="release-desktop.yml"
MOBILE_WORKFLOW="release-mobile.yml"

die() {
  echo "bump: $*" >&2
  exit 1
}

for command in git gh node npm; do
  command -v "$command" >/dev/null 2>&1 || die "$command is required."
done

[[ $# -le 1 ]] || die "Usage: ./bump [patch|minor|major|X.Y.Z]"
[[ "$(git branch --show-current)" == "main" ]] || die "Releases must be created from the main branch."
[[ "$(git remote get-url origin)" == *"DavidVamaiotu/MarinaBookingDesktop.git" ]] || die "origin does not point to MarinaBookingDesktop."
[[ "$(git remote get-url mobile)" == *"DavidVamaiotu/MarinaBookingMobile.git" ]] || die "mobile does not point to MarinaBookingMobile."

gh auth status --hostname github.com >/dev/null
if [[ -n "$(git status --porcelain)" ]]; then
  echo "Including the current tracked and untracked changes in this release."
fi
git fetch --quiet origin main
git fetch --quiet mobile main
HEAD_SHA="$(git rev-parse HEAD)"
[[ "$HEAD_SHA" == "$(git rev-parse origin/main)" ]] || die "Local main is not synchronized with origin/main."
[[ "$HEAD_SHA" == "$(git rev-parse mobile/main)" ]] || die "Local main is not synchronized with mobile/main."

CURRENT_VERSION="$(node -p 'require("./package.json").version')"
node scripts/verify-release-version.js "v$CURRENT_VERSION"

for repo in "$DESKTOP_REPO" "$MOBILE_REPO"; do
  latest="$(gh release view --repo "$repo" --json tagName --jq .tagName)"
  [[ "$latest" == "v$CURRENT_VERSION" ]] || die "$repo latest release is $latest, but the local version is v$CURRENT_VERSION."
done

REQUESTED="${1:-patch}"
NEXT_VERSION="$(node - "$CURRENT_VERSION" "$REQUESTED" <<'NODE'
const current = process.argv[2];
const requested = process.argv[3];
const match = current.match(/^(\d+)\.(\d+)\.(\d+)$/);
if (!match) throw new Error(`Current version is not numeric semver: ${current}`);
const parts = match.slice(1).map(Number);
let next;
if (requested === "patch") next = [parts[0], parts[1], parts[2] + 1];
else if (requested === "minor") next = [parts[0], parts[1] + 1, 0];
else if (requested === "major") next = [parts[0] + 1, 0, 0];
else {
  const explicit = requested.match(/^(\d+)\.(\d+)\.(\d+)$/);
  if (!explicit) throw new Error("Version must be patch, minor, major, or X.Y.Z.");
  next = explicit.slice(1).map(Number);
}
const currentNumber = parts[0] * 1e12 + parts[1] * 1e6 + parts[2];
const nextNumber = next[0] * 1e12 + next[1] * 1e6 + next[2];
if (nextNumber <= currentNumber) throw new Error(`New version ${next.join(".")} must be newer than ${current}.`);
process.stdout.write(next.join("."));
NODE
)"
TAG="v$NEXT_VERSION"

for remote in origin mobile; do
  if git ls-remote --exit-code --tags "$remote" "refs/tags/$TAG" >/dev/null 2>&1; then
    die "$TAG already exists on $remote."
  fi
done

echo "Bumping $CURRENT_VERSION -> $NEXT_VERSION"
npm version "$NEXT_VERSION" --no-git-tag-version
node - "$CURRENT_VERSION" "$NEXT_VERSION" <<'NODE'
const fs = require("node:fs");
const oldVersion = process.argv[2];
const newVersion = process.argv[3];
const gradlePath = "android/app/build.gradle";
let gradle = fs.readFileSync(gradlePath, "utf8");
const code = gradle.match(/versionCode\s+(\d+)/);
const name = gradle.match(/versionName\s+"([^"]+)"/);
if (!code || !name || name[1] !== oldVersion) throw new Error("Android version fields do not match package.json.");
gradle = gradle.replace(/versionCode\s+\d+/, `versionCode ${Number(code[1]) + 1}`);
gradle = gradle.replace(/versionName\s+"[^"]+"/, `versionName "${newVersion}"`);
fs.writeFileSync(gradlePath, gradle);

const readmePath = "README.md";
let readme = fs.readFileSync(readmePath, "utf8");
readme = readme.replaceAll(`MarinaBookingDesktop-Setup-${oldVersion}.exe`, `MarinaBookingDesktop-Setup-${newVersion}.exe`);
fs.writeFileSync(readmePath, readme);
NODE

node scripts/verify-release-version.js "$TAG"
npm run check
npm test
git diff --check

git add -A
git commit -m "Release $NEXT_VERSION"
RELEASE_SHA="$(git rev-parse HEAD)"
git push origin HEAD:main
git push mobile HEAD:main
git tag -a "$TAG" -m "Marina Booking $NEXT_VERSION"
git push origin "$TAG"
git push mobile "$TAG"

find_run() {
  local repo="$1"
  local workflow="$2"
  local run_id=""
  for _ in $(seq 1 40); do
    run_id="$(gh run list --repo "$repo" --workflow "$workflow" --commit "$RELEASE_SHA" --event push --limit 1 --json databaseId --jq '.[0].databaseId // empty')"
    [[ -n "$run_id" ]] && break
    sleep 3
  done
  [[ -n "$run_id" ]] || die "GitHub did not start $workflow for $repo."
  printf '%s' "$run_id"
}

DESKTOP_RUN="$(find_run "$DESKTOP_REPO" "$DESKTOP_WORKFLOW")"
MOBILE_RUN="$(find_run "$MOBILE_REPO" "$MOBILE_WORKFLOW")"

echo "Waiting for desktop release workflow $DESKTOP_RUN"
gh run watch "$DESKTOP_RUN" --repo "$DESKTOP_REPO" --exit-status
echo "Waiting for mobile release workflow $MOBILE_RUN"
gh run watch "$MOBILE_RUN" --repo "$MOBILE_REPO" --exit-status

require_asset() {
  local repo="$1"
  local asset="$2"
  gh release view "$TAG" --repo "$repo" --json assets --jq '.assets[].name' | grep -Fqx "$asset" || die "$repo release is missing $asset."
}

require_asset "$DESKTOP_REPO" "MarinaBookingDesktop-Setup-$NEXT_VERSION.exe"
require_asset "$DESKTOP_REPO" "MarinaBookingDesktop-Setup-$NEXT_VERSION.exe.blockmap"
require_asset "$DESKTOP_REPO" "latest.yml"
require_asset "$MOBILE_REPO" "MarinaBookingMobile.apk"
require_asset "$MOBILE_REPO" "MarinaBookingMobile.apk.sha256"

echo "Release $TAG completed successfully."
echo "Desktop: https://github.com/$DESKTOP_REPO/releases/tag/$TAG"
echo "Mobile:  https://github.com/$MOBILE_REPO/releases/tag/$TAG"
